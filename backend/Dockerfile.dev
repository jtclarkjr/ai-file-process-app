# Development Dockerfile for Bun/Hono backend with hot-reload
FROM oven/bun:1

WORKDIR /app

# Copy package files
COPY package.json bun.lock* ./

# Install dependencies
RUN bun install

# Copy source code (will be overridden by volume mount in dev)
COPY src ./src
COPY tsconfig.json ./

# Environment
ENV LOG_LEVEL=debug
ENV HOST=0.0.0.0
ENV PORT=8080

EXPOSE 8080

# Run with hot reload
CMD ["bun", "run", "dev"]
